    <script>
        document.getElementById("propertyCategory").addEventListener("change", function () {
            let selectedValue = this.value;

            // Hide all specific field groups first
            //document.getElementById("offPlanFields")?.classList.add("hidden");
            //document.getElementById("secondryFields")?.classList.add("hidden");
            //document.getElementById("rentalFields")?.classList.add("hidden");

            // Show rentalContainer if valid
            const rentalContainer = document.getElementById("rentalContainer");
            rentalContainer.classList.remove("hidden");

            // Toggle fields for rent
            const hideWhenRent = document.querySelectorAll(".hide-when-rent");
            if (selectedValue === "For Rent") {
                hideWhenRent.forEach(el => el.classList.remove("hidden"));
            } else {
                hideWhenRent.forEach(el => el.classList.add("hidden"));
            }
        });
    </script>

    <script>
        document.getElementById("propertyType").addEventListener("change", function () {
            let selectedValue = this.value;
            let container = document.getElementById("propertyFieldsContainer");

            // Hide all field sections first
            document.getElementById("apartmentFields").classList.add("hidden");
            document.getElementById("villaFields").classList.add("hidden");
            document.getElementById("commercialFields").classList.add("hidden");

            // Show the container only if a valid option is selected
            if (selectedValue) {
                container.classList.remove("hidden");

                if (selectedValue === "Apartment") {
                    document.getElementById("apartmentFields").classList.remove("hidden");
                } else if (selectedValue === "Villa") {
                    document.getElementById("villaFields").classList.remove("hidden");
                } else if (selectedValue === "Commercial") {
                    document.getElementById("commercialFields").classList.remove("hidden");
                }
            } else {
                container.classList.add("hidden"); // Hide container if no option is selected
            }
        });
    </script>

    <script>
        $('.btnNext').click(function () {
            $('.nav-tabs > .active').next('li').find('a').trigger('click');
        });

        $('.btnPrevious').click(function (e) {
            e.preventDefault();

            const $current = $('.nav-tabs > .active');
            const $prev = $current.prevAll('li').not('.d-none').first();

            if ($prev.length) {
                const $prevLink = $prev.find('a');
                $('.tab-pane').removeClass('active');
                $($prevLink.attr('href')).addClass('active');

                $('.nav-tabs li').removeClass('active');
                $prev.addClass('active');
            }
        });
    </script>
