@section Scripts{

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/js/bootstrap.min.js"></script>

    <script>
        $(document).ready(function () {
            $('.btnNext').click(function (e) {
                e.preventDefault();

                const $this = $(this);
                const currentTab = $this.closest('.tab-pane');
                const nextTabId = $this.data('next-tab');

                const $requiredFields = currentTab.find('[required]');
                let isValid = true;

                $requiredFields.each(function () {
                    if (!this.checkValidity()) {
                        isValid = false;
                        $(this).addClass('is-invalid');
                    } else {
                        $(this).removeClass('is-invalid');
                    }
                });

                currentTab.find('.form-group').each(function () {
                    const radios = $(this).find('input[type="radio"][required]');
                    if (radios.length && !radios.is(':checked')) {
                        isValid = false;
                        $(this).addClass('is-invalid');
                    } else {
                        $(this).removeClass('is-invalid');
                    }
                });

                if (isValid) {
                    // Show the tab in the nav if it's hidden
                    const $navLink = $('.nav-tabs a[href="' + nextTabId + '"]');
                    $navLink.parent().removeClass('d-none');

                    // Activate the tab
                    $('.tab-pane').removeClass('active');
                    $(nextTabId).addClass('active');

                    $('.nav-tabs li').removeClass('active');
                    $navLink.parent().addClass('active');
                } else {
                    alert("Please fill in all required fields before proceeding.");
                }
            });
        });

        $('.btnsave').click(function (e) {
            if (!validateRequiredFields()) {
                e.preventDefault();
                alert("Please fill in all required fields before submitting.");
            }
        });

        function validateRequiredFields() {
            const $requiredFields = $('[required]');
            let isValid = true;

            $requiredFields.each(function () {
                if (!this.checkValidity() || $(this).val().trim() === "") {
                    isValid = false;
                    $(this).addClass('is-invalid');
                } else {
                    $(this).removeClass('is-invalid');
                }
            });

            $('.form-group').each(function () {
                const radios = $(this).find('input[type="radio"][required]');
                if (radios.length && !radios.is(':checked')) {
                    isValid = false;
                    $(this).addClass('is-invalid');
                } else {
                    $(this).removeClass('is-invalid');
                }
            });

            return isValid;
        }


    </script>

    <script>
        function isAllowedKeyPress(event) {
            // Get the character code of the pressed key
            var charCode = event.charCode || event.which;

            // Allow only numbers, letters, hyphens, and underscores
            if (
                (charCode >= 48 && charCode <= 57) || // Numbers 0-9
                (charCode >= 65 && charCode <= 90) || // Uppercase letters A-Z
                (charCode >= 97 && charCode <= 122) || // Lowercase letters a-z
                charCode === 45 || // Hyphen (-)
                charCode === 95    // Underscore (_)
            ) {
                return true;
            }

            // Prevent other characters
            return false;
        }
    </script>

    <script type="text/javascript">
        document.addEventListener('DOMContentLoaded', function () {
            const buttons = document.querySelectorAll('.expand-btn');

            buttons.forEach(button => {
                button.addEventListener('click', function (event) {
                    event.preventDefault(); // Prevent the default action of the button

                    const content = this.previousElementSibling;
                    content.classList.toggle('expanded');
                    this.classList.toggle('expanded');
                    this.textContent = this.classList.contains('expanded') ? 'Collapse' : 'Read more';
                });
            });
        });
    </script>

