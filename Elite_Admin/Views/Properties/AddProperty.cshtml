@model Elite_Admin.Models.PropertyListingVM
@{
    ViewBag.Title = "AddProperty";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    hr {
        margin-bottom: 15px !important;
    }

    .hidden {
        display: none;
    }

    #apartmentFields {
        border-top: 1px solid #283e7a;
        padding-top: 14px;
    }

    #villaFields {
        border-top: 1px solid #283e7a;
        padding-top: 14px;
    }

    #commercialFields {
        border-top: 1px solid #283e7a;
        padding-top: 14px;
    }

    .fade {
        opacity: 1;
    }

    .nav-tabs > li.active > a, .nav-tabs > li.open > a {
        background: #283E7A;
        color: #ffffff;
        border-color: transparent;
    }

    .nav-tabs > li {
        margin-bottom: 5px;
    }

        .nav-tabs > li > a {
            padding: 10px 7px;
            font-size: 13px;
        }

    .nav-tabs {
        border-bottom: 0px solid #dedede !important;
    }

    .tab-content > .active {
        margin-top: 21px;
    }

    a.btn.btn-primary.btnNext {
        background: #1FA7EA !important;
        box-shadow: none !important;
        border: none !important;
    }

    a.btn.btn-primary.btnPrevious {
        background: #1FA7EA;
        box-shadow: none !important;
        border: none !important;
    }

    a.btn.btn-primary.btnsave {
        background: #009fff;
        box-shadow: none !important;
        border: none !important;
    }

    .is-invalid {
        border: 1px solid red !important;
    }

    .form-group.is-invalid label {
        color: red;
    }

    .d-none {
        display: none !important;
    }
</style>
<!-- Row -->
<!-- /Row -->
