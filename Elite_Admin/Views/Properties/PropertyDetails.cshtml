@model Elite_Admin.Models.PropertyDetailsVM

@{
    ViewBag.Title = "Property Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <h2 class="mb-4 mt-5">Property Details</h2>

    <div class="card shadow-lg p-4">
        <div class="text-center mb-4">
            <img src="@Model.MainImage" class="img-fluid rounded" alt="Property Image" style="max-height: 300px; object-fit: cover;">
        </div>

        <table class="tablesaw table-striped table-hover table-bordered table tablesaw-columntoggle">
            <tbody>
                <tr><th>Property Title</th><td>@Model.Title</td></tr>
                <tr><th>Property Type</th><td>@Model.PropertyType</td></tr>
                <tr><th>Listing Type</th><td>@Model.ListingType</td></tr>
                <tr><th>Price Currency</th><td>@Model.PriceCurrency</td></tr>
                <tr>
                    <th>Sub Images</th>
                    <td>
                        @if (!string.IsNullOrEmpty(Model.SubImage))
                        {
                            var images = Model.SubImage.Split(',');
                            foreach (var img in images)
                            {
                                <img src="@img" class="img-fluid rounded mr-2 mb-2" style="max-height: 100px;" />
                            }
                        }
                        else
                        {
                            <span>No sub images available.</span>
                        }
                    </td>
                </tr>

                <tr><th>Property Description</th><td>@Model.Description</td></tr>
                <tr><th>Payment Plan Available</th><td>@(Model.PaymentPlanAvailable == true ? "Yes" : "No")</td></tr>
                <tr><th>Property Slug</th><td>@Model.PropertySlug</td></tr>
                <tr><th>Bedrooms</th><td>@(Model.PropertyType == "Apartment" ? Model.Bedrooms : Model.VillaBedrooms )</td></tr>
                <tr><th>Bathrooms</th><td>@(Model.PropertyType == "Apartment" ? Model.Bathrooms : Model.VillaBathrooms )</td></tr>
                <tr><th>Built-Up Area</th><td>@(Model.PropertyType == "Apartment" ? Model.BuiltUpArea : Model.CommercialBuiltUpArea )</td></tr>
                <tr><th>Plot Size</th><td>@Model.PlotSize sq. ft.</td></tr>
                <tr><th>Furnished</th><td>@(Model.PropertyType == "Apartment" ? Model.Furnished : Model.PropertyType == "Commercial" ? Model.CommercialFurnished : Model.VillaFurnished )</td></tr>
                <tr><th>Floor Level</th><td>@Model.FloorLevel</td></tr>
                <tr><th>Property View</th><td>@Model.PropertyView</td></tr>
                <tr><th>Kitchen Type</th><td>@Model.KitchenType</td></tr>
                <tr><th>Parking Spaces</th><td>@Model.ParkingSpaces</td></tr>

                <tr><th>Community Name</th><td>@Model.CommunityName</td></tr>
                <tr><th>City</th><td>@Model.City</td></tr>
                <tr><th>Neighborhood</th><td>@Model.Neighborhood</td></tr>
                <tr><th>Proximity to Metro</th><td>@Model.ProximityToMetro</td></tr>
                <tr><th>Nearby Landmarks</th><td>@Model.NearbyLandmarks</td></tr>
                <tr><th>Schools & Hospitals Nearby</th><td>@Model.SchoolHospitalProximity</td></tr>
                <tr><th>Swimming Pool</th><td>@(Model.SwimmingPool == true ? "Yes" : "No")</td></tr>
                <tr><th>ROI</th><td>@Model.ROI%</td></tr>
                <tr><th>Rental Yield</th><td>@Model.RentalYield%</td></tr>
                <tr><th>Annual Service Charges</th><td>@Model.AnnualServiceCharges AED</td></tr>
                <tr><th>Mortgage Calculator</th><td>@Model.MortgageCalculator</td></tr>
                <tr><th>Rental Payment Options</th><td>@Model.RentalPaymentOptions</td></tr>
                <tr><th>Cheques Accepted</th><td>@Model.ChequesAccepted</td></tr>
                <tr><th>Listing ID</th><td>@Model.ListingId</td></tr>
                <tr><th>Agent/Owner Name</th><td>@Model.PreviousOwnership</td></tr>
                <tr><th>Real Estate Agency</th><td>@Model.RealEstateAgencyName</td></tr>
                <tr><th>RERA Permit Number</th><td>@Model.RERAPermitNumber</td></tr>

                <tr><th>Payment Method</th><td>@Model.PaymentMethod</td></tr>
                <tr><th>DLD Transfer Fee</th><td>@Model.DLDTransferFee</td></tr>
                <tr><th>Cooling System</th><td>@Model.CoolingSystem</td></tr>
                <tr><th>Pet Policy</th><td>@Model.PetPolicy</td></tr>
                <tr><th>Tenancy Contract Status</th><td>@Model.TenancyContractStatus</td></tr>
                <tr><th>Lease Expiry Date</th><td>@(Model.LeaseExpiryDate?.ToString("MMMM dd, yyyy") ?? "N/A")</td></tr>
                <tr><th>Boost Listing</th><td>@Model.BoostListing</td></tr>
                <tr><th>Priority Placement</th><td>@Model.PriorityPlacement</td></tr>
            </tbody>
        </table>
    </div>
</div>

@if (Model.Amenities != null && Model.Amenities.Any())
{
    <h4 class="mt-15 mb-10">Amenities</h4>
    <table class="table table-bordered mt-10">
        <thead>
            <tr><th>Amenity</th><th>Available</th></tr>
        </thead>
        <tbody>
            @foreach (var amenity in Model.Amenities)
            {
                <tr>
                    <td>@amenity.AmenityName</td>
                    <td>@(amenity.IsAvailable == true ? "Yes" : "No")</td>
                </tr>
            }
        </tbody>
    </table>
}



@section Scripts{

}