    <script>
        $('.btnNext').click(function () {
            $('.nav-tabs > .active').next('li').find('a').trigger('click');
        });

        $('.btnPrevious').click(function (e) {
            e.preventDefault();

            const $current = $('.nav-tabs > .active');
            const $prev = $current.prevAll('li').not('.d-none').first();

            if ($prev.length) {
                const $prevLink = $prev.find('a');
                $('.tab-pane').removeClass('active');
                $($prevLink.attr('href')).addClass('active');

                $('.nav-tabs li').removeClass('active');
                $prev.addClass('active');
            }
        });
    </script>
