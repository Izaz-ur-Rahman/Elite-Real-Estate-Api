    <script>
        $(document).ready(function () {

            //$('.btnNext').click(function (e) {
            //    e.preventDefault();

            //    const currentTab = $(this).closest('.tab-pane');
            //    const nextTabId = $(this).data('next-tab');

            //    if (validateRequiredFields()) {
            //        const $navLink = $('.nav-tabs a[href="' + nextTabId + '"]');
            //        $navLink.parent().removeClass('d-none');

            //        $('.tab-pane').removeClass('active');
            //        $(nextTabId).addClass('active');

            //        $('.nav-tabs li').removeClass('active');
            //        $navLink.parent().addClass('active');
            //    } else {
            //        alert("Please fill in all required fields before proceeding.");
            //    }
            //});


            $('.btnNext').click(function (e) {
                e.preventDefault();

                const $this = $(this);
                const currentTab = $this.closest('.tab-pane');
                const nextTabId = $this.data('next-tab');

                const $requiredFields = currentTab.find('[required]');
                let isValid = true;

                $requiredFields.each(function () {
                    if (!this.checkValidity()) {
                        isValid = false;
                        $(this).addClass('is-invalid');
                    } else {
                        $(this).removeClass('is-invalid');
                    }
                });

                currentTab.find('.form-group').each(function () {
                    const radios = $(this).find('input[type="radio"][required]');
                    if (radios.length && !radios.is(':checked')) {
                        isValid = false;
                        $(this).addClass('is-invalid');
                    } else {
                        $(this).removeClass('is-invalid');
                    }
                });

                if (isValid) {
                    // Show the tab in the nav if it's hidden
                    const $navLink = $('.nav-tabs a[href="' + nextTabId + '"]');
                    $navLink.parent().removeClass('d-none');

                    // Activate the tab
                    $('.tab-pane').removeClass('active');
                    $(nextTabId).addClass('active');

                    $('.nav-tabs li').removeClass('active');
                    $navLink.parent().addClass('active');
                } else {
                    alert("Please fill in all required fields before proceeding.");
                }
            });

            // loadPropertyType();


        });





        $('.btnsave').click(function (e) {
            if (!validateRequiredFields()) {
                e.preventDefault();
                alert("Please fill in all required fields before submitting.");
            }
        });

        function validateRequiredFields() {
            const $requiredFields = $('[required]');
            let isValid = true;

            $requiredFields.each(function () {
                if (!this.checkValidity() || $(this).val().trim() === "") {
                    isValid = false;
                    $(this).addClass('is-invalid');
                } else {
                    $(this).removeClass('is-invalid');
                }
            });

            $('.form-group').each(function () {
                const radios = $(this).find('input[type="radio"][required]');
                if (radios.length && !radios.is(':checked')) {
                    isValid = false;
                    $(this).addClass('is-invalid');
                } else {
                    $(this).removeClass('is-invalid');
                }
            });

            return isValid;
        }


    </script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            function loadPropertyType() {
                let selectedValue = document.getElementById("propertyTypefirst").value;
                let container = document.getElementById("propertyFieldsContainer");

                // Hide all field sections first
                document.getElementById("apartmentFields").classList.add("hidden");
                document.getElementById("villaFields").classList.add("hidden");
                document.getElementById("commercialFields").classList.add("hidden");

                // Show the container only if a valid option is selected
                if (selectedValue) {
                    container.classList.remove("hidden");

                    if (selectedValue === "Apartment") {
                        document.getElementById("apartmentFields").classList.remove("hidden");
                    } else if (selectedValue === "Villa") {
                        document.getElementById("villaFields").classList.remove("hidden");
                    } else if (selectedValue === "Commercial") {
                        document.getElementById("commercialFields").classList.remove("hidden");
                    }
                } else {
                    container.classList.add("hidden");
                }
            }

            // ✅ Trigger when dropdown changes
            document.getElementById("propertyTypefirst").addEventListener("change", loadPropertyType);

            // ✅ Also run it immediately on page load
            loadPropertyType();
        });
    </script>

    <script>
        function isAllowedKeyPress(event) {
            // Get the character code of the pressed key
            var charCode = event.charCode || event.which;

            // Allow only numbers, letters, hyphens, and underscores
            if (
                (charCode >= 48 && charCode <= 57) || // Numbers 0-9
                (charCode >= 65 && charCode <= 90) || // Uppercase letters A-Z
                (charCode >= 97 && charCode <= 122) || // Lowercase letters a-z
                charCode === 45 || // Hyphen (-)
                charCode === 95    // Underscore (_)
            ) {
                return true;
            }

            // Prevent other characters
            return false;
        }
    </script>

    <script type="text/javascript">
        document.addEventListener('DOMContentLoaded', function () {
            const buttons = document.querySelectorAll('.expand-btn');

            buttons.forEach(button => {
                button.addEventListener('click', function (event) {
                    event.preventDefault(); // Prevent the default action of the button

                    const content = this.previousElementSibling;
                    content.classList.toggle('expanded');
                    this.classList.toggle('expanded');
                    this.textContent = this.classList.contains('expanded') ? 'Collapse' : 'Read more';
                });
            });
        });
    </script>

    <script>
        function handlePropertyCategoryChange() {
            let selectedValue = document.getElementById("propertyCategory").value;
            let container = document.getElementById("propertyCategoryContainer");

            // Hide all field sections first
            document.getElementById("offPlanFields").classList.add("hidden");
            document.getElementById("secondryFields").classList.add("hidden");
            document.getElementById("rentalFields").classList.add("hidden");

            // Show the container only if a valid option is selected
            if (selectedValue) {
                container.classList.remove("hidden");

                if (selectedValue === "Off-Plan") {
                    document.getElementById("offPlanFields").classList.remove("hidden");
                } else if (selectedValue === "For Sale") {
                    document.getElementById("secondryFields").classList.remove("hidden");
                } else if (selectedValue === "For Rent") {
                    document.getElementById("rentalFields").classList.remove("hidden");
                }
            } else {
                container.classList.add("hidden"); // Hide container if no option is selected
            }
        }

        // Attach change listener
        document.addEventListener("DOMContentLoaded", function () {
            document.getElementById("propertyCategory").addEventListener("change", handlePropertyCategoryChange);

            // Trigger it on page load
            handlePropertyCategoryChange();
        });
    </script>

