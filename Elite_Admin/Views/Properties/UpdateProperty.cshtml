@model Elite_Admin.Models.PropertyListingVM
@{
    ViewBag.Title = "UpdateProperty";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<style>
    hr {
        margin-bottom: 15px !important;
    }

    .hidden {
        display: none;
    }

    #apartmentFields {
        border-top: 1px solid #283e7a;
        padding-top: 14px;
    }

    #villaFields {
        border-top: 1px solid #283e7a;
        padding-top: 14px;
    }

    #commercialFields {
        border-top: 1px solid #283e7a;
        padding-top: 14px;
    }

    .fade {
        opacity: 1;
    }

    .nav-tabs > li.active > a, .nav-tabs > li.open > a {
        background: #283E7A;
        color: #ffffff;
        border-color: transparent;
    }

    .nav-tabs > li {
        margin-bottom: 5px;
    }

        .nav-tabs > li > a {
            padding: 10px 7px;
            font-size: 13px;
        }

    .nav-tabs {
        border-bottom: 0px solid #dedede !important;
    }

    .tab-content > .active {
        margin-top: 21px;
    }

    a.btn.btn-primary.btnNext {
        background: #1FA7EA !important;
        box-shadow: none !important;
        border: none !important;
    }

    a.btn.btn-primary.btnPrevious {
        background: #1FA7EA;
        box-shadow: none !important;
        border: none !important;
    }

    a.btn.btn-primary.btnsave {
        background: #009fff;
        box-shadow: none !important;
        border: none !important;
    }

    .is-invalid {
        border: 1px solid red !important;
    }

    .form-group.is-invalid label {
        color: red;
    }

    .d-none {
        display: none !important;
    }
</style>
<!-- Row -->
<!-- /Row -->
<div class="row">


    <div class="col-md-12">
        <div class="panel panel-default card-view" style="
    margin-top: 15px;
">
            <div class="panel-heading">
                <div class="pull-left">
                    <h6 class="panel-title txt-dark">Add Property</h6>
                </div>
                <div class="clearfix"></div>
            </div>


            <div class="panel-wrapper collapse in">
                <form action="~/Properties/UpdateProperty" method="post" enctype="multipart/form-data">
                    <div class="panel-body">
                        <ul class="nav nav-tabs">
                            <li class="active"><a href="#tab1" data-toggle="tab">General Information</a></li>
                            <li class="d-none"><a href="#tab2">Property Status</a></li>
                            <li class="d-none"><a href="#tab3">Property Type</a></li>
                            <li class="d-none"><a href="#tab4">Amenities & Facilities</a></li>
                            <li class="d-none"><a href="#tab5" data-toggle="tab">Location & Community</a></li>
                            <li class="d-none"><a href="#tab6" data-toggle="tab">Investment & Payment Plan</a></li>
                            <li class="d-none"><a href="#tab7" data-toggle="tab">Listing & Contact Details</a></li>
                            <li class="d-none"><a href="#tab8" data-toggle="tab">Additional Details</a></li>
                            <li class="d-none"><a href="#tab9" data-toggle="tab">Featured & Sponsored Listings</a></li>
                        </ul>

                        <div class="tab-content">
                            <div class="tab-pane active" id="tab1">
                                <div class="row">
                                    <div class="col-md-4">
                                        <input type="hidden" name="Property.Id" value="@Model.Property.Id" />
                                        <div class="form-group">
                                            <label class="control-label mb-10">Property Title</label>
                                            <input type="text" name="Property.Title" class="form-control" value="@Model.Property.Title" placeholder="Enter Property Title" required>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label class="control-label mb-10">Property Title (AR)</label>
                                            <input type="text" name="Property.Property_Title_AR" value="@Model.Property.Property_Title_AR" class="form-control" placeholder="Enter Property Title Ar">
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label class="control-label mb-10">Property Type</label>
                                            <select id="propertyTypefirst" name="Property.PropertyType" class="form-control">
                                                <option value="">Select Property Type</option>
                                                <option value="Apartment" @(Model.Property.PropertyType == "Apartment" ? "selected" : "")>Apartment</option>
                                                <option value="Villa" @(Model.Property.PropertyType == "Villa" ? "selected" : "")>Villa</option>
                                                <option value="Townhouse" @(Model.Property.PropertyType == "Townhouse" ? "selected" : "")>Townhouse</option>
                                                <option value="Penthouse" @(Model.Property.PropertyType == "Penthouse" ? "selected" : "")>Penthouse</option>
                                                <option value="Commercial" @(Model.Property.PropertyType == "Commercial" ? "selected" : "")>Commercial</option>
                                            </select>



                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label class="control-label mb-10">Listing Type</label>
                                            <select id="propertyCategory" name="Property.ListingType" class="form-control">
                                                <option value="">Select Listing Type</option>
                                                <option value="For Rent" @(Model.Property.ListingType == "For Rent" ? "selected" : "")>For Rent</option>
                                                <option value="Off-Plan" @(Model.Property.ListingType == "Off-Plan" ? "selected" : "")>Off-Plan</option>
                                                <option value="For Sale" @(Model.Property.ListingType == "For Sale" ? "selected" : "")>For Sale</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label class="control-label mb-10">Price Currency</label>
                                            <select name="Property.PriceCurrency" class="form-control">
                                                <option value="">Select Currency</option>
                                                <option value="AED" @(Model.Property.PriceCurrency == "AED" ? "selected" : "")>AED</option>
                                                <option value="$" @(Model.Property.PriceCurrency == "$" ? "selected" : "")>USD</option>
                                            </select>
                                        </div>
                                    </div>

                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label class="control-label mb-10">Property Size</label>
                                            <input type="number" step="0.01" name="Property.Property_Size" value="@Model.Property.Property_Size" class="form-control" />
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label class="control-label mb-10">Size Unit</label>
                                            <select name="Property.Property_Size_Unit"  class="form-control">
                                                <option value="sqft">Sqft</option>
                                                <option value="sqm">Sqm</option>
                                                <option value="sqyard">Sq Yard</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label class="control-label mb-10">Plot Area</label>
                                            <input type="number" step="0.01" name="Property.plotArea" value="@Model.Property.plotArea" class="form-control" />
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label class="control-label mb-10">Furnished</label>
                                            <select name="Property.Furnished" class="form-control">
                                                <option value="No">No</option>
                                                <option value="Yes">Yes</option>
                                            </select>
                                        </div>
                                    </div>


                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label class="control-label mb-10">Main Image</label>
                                            <input type="file" name="MainImage" class="form-control">
                                            <input type="hidden" name="ExistingMainImage" value="@Model.Property.MainImage" />
                                            @if (!string.IsNullOrEmpty(Model.Property.MainImage))
                                            {
                                                <img src="@ViewBag.baseapiurl@Model.Property.MainImage" alt="Main Image" width="100" />
                                            }
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label class="control-label mb-10">Sub Images</label>
                                            <input type="file" name="SubImageFiles" class="form-control" multiple />

                                            <input type="hidden" name="ExistingSubImage" value="@Model.Property.SubImage" />

                                            @if (!string.IsNullOrEmpty(Model.Property.SubImage))
                                            {
                                                var images = Model.Property.SubImage.Split(',');
                                                foreach (var img in images)
                                                {
                                                    <img src="@ViewBag.baseapiurl@img" alt="Sub Image" width="100" style="margin:5px;" />
                                                }

                                            }
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label class="control-label mb-10">Payment Plan</label>
                                            <input type="text" name="Property.PaymentPlanAvailableDescription" value="@Model.Property.PaymentPlanAvailableDescription" class="form-control" required placeholder="Enter Property plan">
                                            @*<div class="radio-list">
                    <div class="radio-inline pl-0">
                        <span class="radio radio-info">
                            <input type="radio" name="Property.PaymentPlanAvailable" id="radio_yes" value="true" @(Model.Property.PaymentPlanAvailable == true ? "checked" : "")>
                            <label for="radio_yes">Yes</label>
                        </span>
                    </div>
                    <div class="radio-inline">
                        <span class="radio radio-info">
                            <input type="radio" name="Property.PaymentPlanAvailable" id="radio_no" value="false" @(Model.Property.PaymentPlanAvailable == false ? "checked" : "")>
                            <label for="radio_no">No</label>
                        </span>
                    </div>
                </div>*@
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label class="control-label mb-10">Property Slug</label>
                                            <input type="text" name="Property.PropertySlug" id="slug" value="@Model.Property.PropertySlug" class="form-control" placeholder="Enter Property Slug" onkeypress="return isAllowedKeyPress(event);" />
                                        </div>
                                    </div>

                                </div>
                                <div class="col-md-12" style="text-align:right">
                                    <button type="submit" class="btn btn-primary btnsave">Update</button>
                                    <a href="#" class="btn btn-primary btnNext" data-next-tab="#tab2">Next</a>
                                </div>
                            </div>

                            <!-- Tab 2 - Property Status -->
                            <div class="tab-pane" id="tab2">

                                <div id="propertyCategoryContainer" class="hidden">
                                    <div class="row">
                                        <div class="col-md-12">
                                            <!-- Off-Plan Fields -->
                                            <div id="offPlanFields" class="hidden mt-3">
                                                <div class="col-md-4">
                                                    <div class="form-group">
                                                        <label class="control-label mb-10">Developer Name</label>
                                                        <input type="text" name="Property.DeveloperName" value="@Model.Property.DeveloperName" class="form-control" placeholder="Enter Developer Name">
                                                    </div>
                                                </div>
                                                <div class="col-md-4">
                                                    <div class="form-group">
                                                        <label class="control-label mb-10">Handover Date</label>
                                                        <input type="date" name="Property.HandoverDate" value="@Model.Property.HandoverDate" class="form-control" placeholder="Enter Handover Date">
                                                    </div>
                                                </div>
                                                <div class="col-md-4">
                                                    <div class="form-group">
                                                        <label class="control-label mb-10">Payment Plan Structure</label>
                                                        <input type="text" name="Property.PaymentPlanStructure" value="@Model.Property.PaymentPlanStructure" class="form-control" placeholder="Enter Payment Plan Structre">
                                                    </div>
                                                </div>
                                                <div class="col-md-4">
                                                    <div class="form-group">
                                                        <label class="control-label mb-10">Post-Handover Payment</label>
                                                        <input type="text" name="Property.PostHandoverPayment" value="@Model.Property.PostHandoverPayment" class="form-control" placeholder="Enter Post-Handover Pay">
                                                    </div>
                                                </div>
                                                <div class="col-md-4">
                                                    <div class="form-group">
                                                        <label class="control-label mb-10">Construction Status</label>
                                                        <select name="Property.ConstructionStatus" class="form-control">
                                                            <option value="Planned" @(Model.Property.ConstructionStatus == "Planned" ? "selected" : "")>Planned</option>
                                                            <option value="Under Construction" @(Model.Property.ConstructionStatus == "Under Construction" ? "selected" : "")>Under Construction</option>
                                                            <option value="Completed" @(Model.Property.ConstructionStatus == "Completed" ? "selected" : "")>Completed</option>
                                                        </select>
                                                    </div>
                                                </div>
                                                <div class="col-md-4">
                                                    <div class="form-group">
                                                        <label class="control-label mb-10">Price</label>
                                                        <input type="text" name="Property.OffPrice" value="@Model.Property.OffPrice" class="form-control" placeholder="Enter Price">
                                                    </div>
                                                </div>

                                                <div class="col-md-4">
                                                    <div class="form-group">
                                                        <label class="control-label mb-10">Offplan Sale Type</label>
                                                        <input type="text" name="Property.offplanDetails_saleType" value="@Model.Property.offplanDetails_saleType" class="form-control" />
                                                    </div>
                                                </div>
                                                <div class="col-md-4">
                                                    <div class="form-group">
                                                        <label class="control-label mb-10">DLD Waiver</label>
                                                        <input type="text" name="Property.offplanDetails_dldWaiver" value="@Model.Property.offplanDetails_dldWaiver" class="form-control" />
                                                    </div>
                                                </div>
                                                <div class="col-md-4">
                                                    <div class="form-group">
                                                        <label class="control-label mb-10">Amount Paid</label>
                                                        <input type="text" name="Property.offplanDetails_amountPaid" value="@Model.Property.offplanDetails_amountPaid" class="form-control" />
                                                    </div>
                                                </div>
                                                <div class="col-md-4">
                                                    <div class="form-group">
                                                        <label class="control-label mb-10">Original Price</label>
                                                        <input type="text" name="Property.offplanDetails_originalPrice" value="@Model.Property.offplanDetails_originalPrice" class="form-control" />
                                                    </div>
                                                </div>

                                                @*<div class="col-md-4">
            <div class="form-group">
                <label class="control-label mb-10">Service Charges</label>
                <input type="text" name="Property.ServiceCharges" value="@Model.Property.ServiceCharges" class="form-control" placeholder="Enter Service Charges">
            </div>
        </div>*@
                                                @*<div class="col-md-4">
            <div class="form-group">
                <label class="control-label mb-10">Showroom Available</label>
                <div class="radio-list">
                    <div class="radio-inline pl-0">
                        <span class="radio radio-info">
                            <input type="radio" name="Property.ShowroomAvailable" id="showroom_yes" value="true">
                            <label for="showroom_yes">Yes</label>
                        </span>
                    </div>
                    <div class="radio-inline">
                        <span class="radio radio-info">
                            <input type="radio" name="Property.ShowroomAvailable" id="showroom_no" value="false">
                            <label for="showroom_no">No</label>
                        </span>
                    </div>
                </div>
            </div>
        </div>*@
                                            </div>

                                            <!-- Secondry Fields -->
                                            <div id="secondryFields" class="hidden mt-3">
                                                <div class="col-md-4">
                                                    <div class="form-group">
                                                        <label class="control-label mb-10">Property Age</label>
                                                        <select name="Property.PropertyAge" class="form-control">
                                                            <option value="10" @(Model.Property.PropertyAge == "10" ? "selected" : "")>10</option>
                                                            <option value="15" @(Model.Property.PropertyAge == "15" ? "selected" : "")>15</option>
                                                            <option value="25" @(Model.Property.PropertyAge == "25" ? "selected" : "")>25</option>
                                                        </select>
                                                    </div>
                                                </div>
                                                <div class="col-md-4">
                                                    <div class="form-group">
                                                        <label class="control-label mb-10">Price</label>
                                                        <input type="text" name="Property.SalePrice" value="@Model.Property.SalePrice" class="form-control" placeholder="Enter Price">
                                                    </div>
                                                </div>
                                                <div class="col-md-4">
                                                    <div class="form-group">
                                                        <label class="control-label mb-10">Tenancy Status</label>
                                                        <select name="Property.TenancyStatus" class="form-control">
                                                            <option value="Vacant" @(Model.Property.TenancyStatus == "Vacant" ? "selected" : "")>Vacant</option>
                                                            <option value="Occupied" @(Model.Property.TenancyStatus == "Occupied" ? "selected" : "")>Occupied</option>
                                                        </select>
                                                    </div>
                                                </div>
                                                <div class="col-md-4">
                                                    <div class="form-group">
                                                        <label class="control-label mb-10">Service Charges</label>
                                                        <input type="text" name="Property.ServiceCharges" value="@Model.Property.ServiceCharges" class="form-control" placeholder="Enter Service Charges">
                                                    </div>
                                                </div>
                                                <div class="col-md-4">
                                                    <div class="form-group">
                                                        <label class="control-label mb-10">Mortgage Status</label>
                                                        <select name="Property.MortgageStatus" class="form-control">
                                                            <option value="Mortgaged" @(Model.Property.MortgageStatus == "Mortgaged" ? "selected" : "")>Mortgaged</option>
                                                            <option value="Clear" @(Model.Property.MortgageStatus == "Clear" ? "selected" : "")>Clear</option>
                                                        </select>
                                                    </div>
                                                </div>
                                                <div class="col-md-4">
                                                    <div class="form-group">
                                                        <label class="control-label mb-10">Previous Ownership</label>
                                                        <div class="radio-list">

                                                            <div class="radio-inline pl-0">
                                                                <span class="radio radio-info">
                                                                    <input type="radio" name="Property.PreviousOwnership" id="previous_yes" value="true" @(Model.Property.PreviousOwnership == true ? "checked" : "")>
                                                                    <label for="previous_yes">Yes</label>
                                                                </span>
                                                            </div>
                                                            <div class="radio-inline">
                                                                <span class="radio radio-info">
                                                                    <input type="radio" name="Property.PreviousOwnership" id="previous_no" value="false" @(Model.Property.PreviousOwnership == false ? "checked" : "")>
                                                                    <label for="previous_no">No</label>
                                                                </span>
                                                            </div>

                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-md-4">
                                                    <div class="form-group">
                                                        <label class="control-label mb-10">Title Deed Available</label>
                                                        <div class="radio-list">
                                                            <div class="radio-inline pl-0">
                                                                <span class="radio radio-info">
                                                                    <input type="radio" name="Property.TitleDeedAvailable" id="deed_yes" value="true" @(Model.Property.TitleDeedAvailable == true ? "checked" : "")>
                                                                    <label for="deed_yes">Yes</label>
                                                                </span>
                                                            </div>
                                                            <div class="radio-inline">
                                                                <span class="radio radio-info">
                                                                    <input type="radio" name="Property.TitleDeedAvailable" id="deed_no" value="false" @(Model.Property.TitleDeedAvailable == false ? "checked" : "")>
                                                                    <label for="deed_no">No</label>
                                                                </span>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>

                                            <!-- Rental Fields -->
                                            <div id="rentalFields" class="hidden mt-3">
                                                <div class="col-md-4">
                                                    <div class="form-group">
                                                        <label class="control-label mb-10">Price</label>
                                                        <input type="text" name="Property.RentalPrice" value="@Model.Property.RentalPrice" class="form-control" placeholder="Enter Price">
                                                    </div>
                                                </div>
                                                <div class="col-md-4">
                                                    <div class="form-group">
                                                        <label class="control-label mb-10">Rent Frequency</label>
                                                        <select name="Property.Rent_Frequency" class="form-control">
                                                            <option value="Monthly">Monthly</option>
                                                            <option value="Yearly">Yearly</option>
                                                            <option value="Weekly">Weekly</option>
                                                            <option value="">N/A</option>
                                                        </select>
                                                    </div>
                                                </div>
                                                <div class="col-md-4">
                                                    <div class="form-group">
                                                        <label class="control-label mb-10">Payment Terms</label>
                                                        <select name="Property.PaymentTerms" class="form-control">
                                                            <option value="Yearly" @(Model.Property.PaymentTerms == "Yearly" ? "selected" : "")>Yearly</option>
                                                            <option value="Quarterly" @(Model.Property.PaymentTerms == "Quarterly" ? "selected" : "")>Quarterly</option>
                                                            <option value="Monthly" @(Model.Property.PaymentTerms == "Monthly" ? "selected" : "")>Monthly</option>
                                                        </select>
                                                    </div>
                                                </div>
                                                <div class="col-md-4">
                                                    <div class="form-group">
                                                        <label class="control-label mb-10">Cheques Accepted</label>
                                                        <select name="Property.ChequesAccepted" class="form-control">
                                                            <option value="1" @(Model.Property.ChequesAccepted == "1" ? "selected" : "")>1</option>
                                                            <option value="2" @(Model.Property.ChequesAccepted == "2" ? "selected" : "")>2</option>
                                                            <option value="3" @(Model.Property.ChequesAccepted == "3" ? "selected" : "")>3</option>
                                                        </select>
                                                    </div>
                                                </div>
                                                <div class="col-md-4">
                                                    <div class="form-group">
                                                        <label class="control-label mb-10">Commission Fee</label>
                                                        <input type="text" name="Property.CommissionFee" value="@Model.Property.CommissionFee" class="form-control" placeholder="Enter Commission Fee">
                                                    </div>
                                                </div>
                                                <div class="col-md-4">
                                                    <div class="form-group">
                                                        <label class="control-label mb-10">Tenancy Contract Length</label>
                                                        <input type="text" name="Property.TenancyContractLength" value="@Model.Property.TenancyContractLength" class="form-control" placeholder="Enter Contract Length">
                                                    </div>
                                                </div>
                                                <div class="col-md-4">
                                                    <div class="form-group">
                                                        <label class="control-label mb-10">Vacating Notice Period</label>
                                                        <input type="text" name="Property.VacatingNoticePeriod" value="@Model.Property.VacatingNoticePeriod" class="form-control" placeholder="Enter Notice Period">
                                                    </div>
                                                </div>
                                                <div class="col-md-4">
                                                    <div class="form-group">
                                                        <label class="control-label mb-10">Deposit</label>
                                                        <div class="radio-list">
                                                            <div class="radio-inline pl-0">
                                                                <span class="radio radio-info">
                                                                    <input type="radio" name="Property.Deposit" id="deposit_yes" value="true" @(Model.Property.Deposit == true ? "checked" : "")>
                                                                    <label for="deposit_yes">Yes</label>
                                                                </span>
                                                            </div>
                                                            <div class="radio-inline">
                                                                <span class="radio radio-info">
                                                                    <input type="radio" name="Property.Deposit" id="deposit_no" value="false" @(Model.Property.Deposit == false ? "checked" : "")>
                                                                    <label for="deposit_no">No</label>
                                                                </span>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-12" style="text-align:right">
                                    <button type="submit" class="btn btn-primary btnsave">Update</button>
                                    <a href="#" class="btn btn-primary btnNext" data-next-tab="#tab3">Next</a>
                                    <a class="btn btn-primary btnPrevious">Previous</a>
                                </div>
                            </div>

                            <!-- Tab 3 - Property Type -->
                            <div class="tab-pane" id="tab3">
                                <div class="col-md-4" style="display:none;">
                                    <div class="form-group">
                                        <label class="control-label mb-10">Property Type</label>
                                        <select id="propertyType" class="form-control">
                                            <option value="">Select Property Type</option>
                                            <option value="Apartment" @(Model.Property.PropertyType == "Apartment" ? "selected" : "")>Apartment Studio</option>
                                            <option value="Villa" @(Model.Property.PropertyType == "Villa" ? "selected" : "")>Villa/Townhouse</option>
                                            <option value="Commercial" @(Model.Property.PropertyType == "Commercial" ? "selected" : "")>Commercial</option>
                                        </select>
                                    </div>
                                </div>
                                <div id="propertyFieldsContainer" class="hidden">
