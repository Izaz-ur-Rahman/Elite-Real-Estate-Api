<div id="popup-message" style="display:none; position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); background-color: white; border: 2px solid #05a494; padding: 20px; border-radius: 10px; box-shadow: 0px 4px 8px rgba(0, 0, 0, 0.1); text-align:center;">
    <h3 style="color: #05a494;">
        You're All Set!
    </h3>
    <p>Keep connected with us for weekly newsletter.</p>
    <button onclick="closePopup()" class="btn btn-primary">Close</button>
</div>

<div id="noAlert"></div>


