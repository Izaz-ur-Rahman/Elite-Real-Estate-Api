<!-- Content Section -->
<div class="container content-wrapper">
    <div class="row mt-5">
        <div class="col-12 col-md-8">
            <div class="article-section">
                <div class="cart-main">
                    <div class="sm-img">
                        <img src="~/EliteFiles/ProfileImages/@ViewBag.userdata.Profileimage" class="rounded-circle user-photo" alt="Profile pic" style="width: 40px;">
                    </div>
                    <div class="ms-2">
                        <p class="cart-wriiten">Written By</p>
                        <p class="cart-nadeem">@ViewBag.userdata.Name</p>
                        <p class="cart-nadeem"> @(Model.PublishingDate?.ToString("yyyy-MMM-dd"))</p>
                    </div>
                </div>

                <h1 class="article-title">@Model.Title</h1>

                @Html.Raw(Model.BlogDetails)
            </div>



            <section class="pt-5 pb-5">
                <div class="container">
                    <div class="row">
                        <div class="col-6">
                            <h3 class="mb-3">Popular Blogs </h3>
                        </div>
                        @*<div class="col-6 text-right">
                                <a class="btn btn-primary mb-3 mr-1" href="#carouselExampleIndicators3" role="button" data-slide="prev">
                                    <i class="fa fa-arrow-left"></i>
                                </a>
                                <a class="btn btn-primary mb-3 " href="#carouselExampleIndicators3" role="button" data-slide="next">
                                    <i class="fa fa-arrow-right"></i>
                                </a>
                            </div>*@
                        <div class="col-12">
                            <div id="carouselExampleIndicators3" class="carousel slide">
                                <div class="carousel-inner">
                                    @for (int i = 0; i < ViewBag.Papular.Count; i += 3)
                                    {
                                        <div class="carousel-item @(i == 0 ? "active" : "")">
                                            <div class="row">
                                                @for (int j = i; j < i + 3 && j < ViewBag.Papular.Count; j++)
                                                {
                                                    <div class="col-md-6  col-sm-12">
                                                        <a href="~/blog/@ViewBag.Papular[j].Slug">
                                                            <img src="~/raidetimefiles/blogfiles/@ViewBag.Papular[j].CoverImage" alt="Blog Image" style="border: 1px solid lightgrey;">
                                                            <div class="blog-content">
                                                                <div class="time-hour">
                                                                    <p>@ViewBag.Papular[j].Blog_readTime Min Read</p>
                                                                    <p>@(ViewBag.Papular[j].PublishingDate?.ToString("yyyy-MMM-dd"))</p>
                                                                </div>
                                                                <p class="cart-hd">@ViewBag.Papular[j].Title</p>
                                                                <p class="cutoff-text">@ViewBag.Papular[j].MetaDescription</p>
                                                                <div class="cart-main">
                                                                    <div class="sm-img">
                                                                        <img src="~/raidetimefiles/ProfileImages/@ViewBag.Papular[j].Profileimage" class="rounded-circle user-photo" alt="Profile pic" style="width: 50px; height: 50px; max-width: 50px !important;">
                                                                    </div>
                                                                    <div class="ms-3">
                                                                        <p class="cart-wriiten">Written By</p>
                                                                        <p class="cart-nadeem">@ViewBag.Papular[j].CreatedBy</p>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </a>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
                                <a class="carousel-control-prev" href="#carouselExampleIndicators3" role="button" data-bs-slide="prev">
                                    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                                    <span class="visually-hidden">Previous</span>
                                </a>
                                <a class="carousel-control-next" href="#carouselExampleIndicators3" role="button" data-bs-slide="next">
                                    <span class="carousel-control-next-icon" aria-hidden="true"></span>
                                    <span class="visually-hidden">Next</span>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

        </div>

        <div class="col-12 col-md-4">
            <div class="author-profile" style="position:sticky;top:-415px;">
                <p class="author-detail">Author Profile</p>
                <div class="author-img">
                    <img src="~/EliteFiles/ProfileImages/@ViewBag.userdata.Profileimage" class="rounded-circle user-photo" alt="Profile pic" style="width: 80px;">

                </div>
                <!-- <img src="author-placeholder.png" alt="Author Image"> -->
                <h4 class="mt-3" style="font-size: 19px; font-weight: 700; color: #05a494 !important; ">@ViewBag.userdata.Name</h4>
                <p style="margin-bottom: 5px !important; font-size: 15px; font-weight: 700; color: black;">@ViewBag.profiledata.Position</p>
                <h4 style="margin-bottom: 5px !important; font-size: 19px; font-weight: 700; color: #05a494 !important;"> Bio</h4>
                <p style="margin-bottom: 5px !important; font-size: 14px; text-align: -webkit-auto;">@ViewBag.profiledata.Bio</p>
                <h4 style="font-size: 19px; font-weight: 700; color: #05a494 !important; "> Social links</h4>
                <div class="social-links">
                    <a href="@ViewBag.profiledata.LinkedIn" target="_blank" class="btn btn-soft-yellow"><i class="fa fa-linkedin m-r-5"></i></a>
                    <a href="@ViewBag.profiledata.Facebook" target="_blank" class="btn btn-soft-yellow"> <i class="fa fa-facebook m-r-5"></i></a>
                    <a href="@ViewBag.profiledata.Twitter" target="_blank" class="btn btn-soft-yellow"><i class="fa fa-twitter m-r-5"></i></a>


                </div>
                <h4 class="mt-3" style="font-size: 19px; font-weight: 700; color: #05a494 !important; ">Tags</h4>
                <div class="main-tag">
                    @for (var i = 0; i < Model.Tags.Split(',').Length; i++)
                    {

                        <button class="tags">@Model.Tags.Split(',')[i]</button>


                    }

                </div>
                <div class="side-box card mt-5" style="padding:10px;border-radius:10px;margin-top:10px;">
                    <div class="sub-side-box" style="width:90%;margin:auto;">
                        <h5 style=" color: #05a494;">
                            Stay on Top of Time and Attendance Trends
                        </h5>
                        <p style=" text-align: -webkit-auto;">
                            Get weekly insights and strategies into your inbox  to streamline your workforce management!
                        </p>
                        <form id="subscribe-newsletter">
                            <div class="mb-3">
                                <input type="hidden" id="blogId" name="blogId" value="@Model.Id" />
                                <input type="hidden" id="Blogtitle" name="Blogtitle" value="@Model.Title" />
                                <input type="text" class="form-control" name="Name" id="name" placeholder="Enter your name" required>
                            </div>
                            <div class="mb-3">
                                <input type="email" class="form-control" name="Email" id="email" placeholder="Enter your email" required>
                            </div>
                            <input type="hidden" name="captchakey" id="captchakey" class="captchakey" />

                            <button type="submit" id="submit-button" class=" btn btn-primary rounded-pill btn-login w-100 mb-2">Submit</button>



                        </form>
                    </div>
                </div>

                <div style="text-align:center;">
                    <button id="share-button" type="button" class="btn btn-primary rounded-pill btn-login w-50 mb-2 mt-3 uil uil-share">Share</button>

                </div>


            </div>
        </div>

    </div>
</div>

<!-- Loader element -->
<div id="loader" style="display:none; position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); background-color: #05a494; padding: 20px; border-radius: 50%; width: 50px; height: 50px;">
