
@{
    ViewBag.Title = "Getcontactus";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/Content/assets/vendor/jquery-datatable/dataTables.bootstrap4.min.css">
<link rel="stylesheet" href="~/Content/assets/vendor/jquery-datatable/fixedeader/dataTables.fixedcolumns.bootstrap4.min.css">
<link rel="stylesheet" href="~/Content/assets/vendor/jquery-datatable/fixedeader/dataTables.fixedheader.bootstrap4.min.css">


<style>
    .panel-heading {
        padding: 10px 0px;
    }
    .dataTables_wrapper .dataTables_filter input, .dataTables_wrapper .dataTables_length select {
        height: 32px;
    }
</style>

<div class="row" style="margin-top: 28px;">
    <div class="col-sm-12">
        <div class="panel panel-default card-view">
            <div class="">
               
                <div class="panel-heading">
                    <div class="pull-left">
                        <h3 class="panel-title txt-dark">Contact us</h3>
                    </div>
                   
                </div>


                <div class="row clearfix">
                    <div class="col-lg-12">
                        <div class="panel-wrapper collapse in">
                            <div class="panel-body">
                                <div class="table-responsive">
                                    <table class="table table-bordered table-striped table-hover dataTable js-exportable" id="tbldetails">
                                        <thead>
                                            <tr>
                                                <th>Name</th>
                                                <th>Email</th>
                                                <th>Phone Number</th>
                                                <th>Message</th>
                                                @*<th>Page Source</th>*@
                                                <th>Property Name</th>
                                                <th>Agent Name</th>
                                                <th>Source</th>
                                                <th>Status</th>
                                            </tr>
                                        </thead>

                                        <tbody>
                                            @foreach (var item in Model)
                                            {
                                                <tr>
                                                    <td>@item.FirstName</td>

                                                    <td>@item.Email</td>

                                                    <td>@item.PhoneNumber</td>
                                                    <td>@item.Message</td>
                                                    @*<td>@item.PageSource</td>*@
                                                    <td>@item.PropertyName</td>
                                                    <td>@item.AgentName</td>
                                                    <td>@item.Source</td>
                                                    <td>@item.Status</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>

                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts{
    <script src="~/Content/assets/bundles/datatablescripts.bundle.js"></script>
    <script src="~/Content/assets/vendor/jquery-datatable/buttons/dataTables.buttons.min.js"></script>
    <script src="~/Content/assets/vendor/jquery-datatable/buttons/buttons.bootstrap4.min.js"></script>
    <script src="~/Content/assets/vendor/jquery-datatable/buttons/buttons.colVis.min.js"></script>
    <script src="~/Content/assets/vendor/jquery-datatable/buttons/buttons.html5.min.js"></script>
    <script src="~/Content/assets/vendor/jquery-datatable/buttons/buttons.print.min.js"></script>
    <script>
        $(document).ready(function () {
            $("#tbldetails").dataTable();
        });
    </script>

}





