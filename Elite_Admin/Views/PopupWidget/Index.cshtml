
@{
    ViewBag.Title = "Index";
}


@{
    ViewBag.Title = "Index";
}
<link rel="stylesheet" href="~/Content/assets/vendor/jquery-datatable/dataTables.bootstrap4.min.css">
<link rel="stylesheet" href="~/Content/assets/vendor/jquery-datatable/fixedeader/dataTables.fixedcolumns.bootstrap4.min.css">
<link rel="stylesheet" href="~/Content/assets/vendor/jquery-datatable/fixedeader/dataTables.fixedheader.bootstrap4.min.css">
<div class="container-fluid">
    <div class="col-lg-12">
        <div class="card">
            <div class="header">
                <h2>Popup Widjet List<small>List of All Popup Widjet</small> </h2>
            </div>
            <div class="body">
                <div class="table-responsive">
                    <table class="table table-bordered table-striped table-hover dataTable js-exportable" id="tbldetails">

                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Headlines</th>
                                @*<th>Sentence</th>*@
                                @*<th>Image</th>*@
                                <th>Form Name</th>
                                <th>Form Email</th>
                                <th>Trigger Type</th>
                                <th>Display Rule</th>
                                <th>Page Link To Show</th>
                                <th>Display Frequency</th>
                                <th>Is Active</th>
                                @*<th>Status</th>*@
                                <th>Submitted Date</th>
                                @*<th>Update Date</th>
                                    <th>Created By</th>*@
                                <th></th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.Name</td>
                                    <td>@item.Headlines</td>
                                    @*<td>@item.Sentence</td>*@
                                    @*<td>@item.Image</td>*@
                                    <td>@item.Form_Name</td>
                                    <td>@item.Form_Email</td>
                                    <td>@item.TriggerType</td>
                                    <td>@item.DisplayRule</td>
                                    <td>@item.PagelinkToShow</td>
                                    <td>@item.DisplayFrequency</td>
                                    @if (item.IsActive == true)
                                    {
                                        <td><a href="javascript:void(0)" onclick="ftnDelete_Active('@item.Id','InActive')"> <span class="badge badge-success">@(item.IsActive ? "Active" : "InActive")</span></a> </td>
                                    }
                                    else
                                    {
                                        <td><a href="javascript:void(0)" onclick="ftnDelete_Active('@item.Id','Active')"> <span class="badge badge-danger">@(item.IsActive ? "Active" : "InActive")</span></a> </td>

                                    }
                                    @*<td>@item.Status</td>*@
                                    <td>@(item.EntryDate.ToString("MMMM d, yyyy"))</td>
                                    @*<td>@(item.UpdateDate.ToString("MMMM d, yyyy"))</td>
                                        <td>@item.Createdby</td>*@
                                    <td>

                                        <a href="~/PopupWidget/update_popWidjet?id=@item.Id"><i class="fa fa-edit"></i></a>

                                        <a href="javascript:void(0)" onclick="ftnDelete_Active('@item.Id','Delete')"><i class="fa fa-trash"></i></a>

                                    </td>
                                </tr>
}
                        </tbody>


                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts{
    <script src="~/Content/assets/bundles/datatablescripts.bundle.js"></script>
    <script src="~/Content/assets/vendor/jquery-datatable/buttons/dataTables.buttons.min.js"></script>
    <script src="~/Content/assets/vendor/jquery-datatable/buttons/buttons.bootstrap4.min.js"></script>
    <script src="~/Content/assets/vendor/jquery-datatable/buttons/buttons.colVis.min.js"></script>
    <script src="~/Content/assets/vendor/jquery-datatable/buttons/buttons.html5.min.js"></script>
    <script src="~/Content/assets/vendor/jquery-datatable/buttons/buttons.print.min.js"></script>
    <script>
        $(document).ready(function () {


            $("#tbldetails").dataTable();
        });
    </script>
    <script>

            function ftnDelete_Active(id, type) {
                swal({
                    title: "Are you sure?",
                    text: "to " + type + " it",
                    type: "warning",
                    showCancelButton: true,
                    confirmButtonColor: "#dc3545",
                    confirmButtonText: "Yes",
                    cancelButtonText: "No",
                    closeOnConfirm: false,
                    closeOnCancel: false
                }, function (isConfirm) {
                    if (isConfirm) {
                        window.location = "@Url.Action("PopupDelete_Active", "PopupWidget")?id=" + id + "&type=" + type;
                    } else {
                        swal.close();  // Close the popup when "No" is clicked
                    }
                });
            }

    </script>
    <script>
        var msg = '@TempData["msg"]';
        if (msg != null) {
            if (msg == "published") {

                $(document).ready(function () {
                    funtionalert('Success!', 'Pop published Successfully', 'success');

                });


            }
            if (msg == "Updated") {
                $(document).ready(function () {
                    funtionalert('Success!', 'Pop Updated Successfully', 'success');

                });
            }
            if (msg == "Added") {
                $(document).ready(function () {
                    funtionalert('Success!', 'Pop Added Successfully', 'success');

                });
            }
            if (msg == "Deleted") {
                $(document).ready(function () {
                    funtionalert('Success!', 'Pop Deleted Successfully', 'error');

                });
            }
        }
    </script>
}


