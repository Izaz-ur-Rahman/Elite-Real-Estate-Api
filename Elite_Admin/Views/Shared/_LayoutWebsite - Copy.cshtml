    <script>
        function showpopwidjet() {
            $.ajax({
                url: "@Url.Action("PopNotification", "Home")",  // The URL for the request
                type: 'POST',                        // Request method (POST, GET, etc.)
                dataType: 'json',                    // Data type expected from the server
                contentType: 'application/json; charset=utf-8', // Content type being sent to the server
                data: JSON.stringify({
                    links: window.location.href
                }),
                success: function (response) {

                    // Update the image
                    $('#product-image').attr('src', '/raidetimefiles/Popupfiles/' + response.Image); // Change the image source to the new one
                    $('#product-image').attr('alt', response.Image); // Optionally change the alt text

                    // Update the title
                    $('h5.mb-2.mt-3').text(response.Headlines); // Update the title text

                    // Update the paragraph
                    $('p.mb-4').text(response.Sentence);
                    $("#closepop").val(response.Id)// Update the paragraph text
                    triggertype(response.TriggerType);
                    // Handle the success scenario
                    console.log('Success:', response);
                    if (response.showlinkbutton == true) {
                        $("#btnpoplink").show();
                        $("#btnpoplink").text(response.ButtonText);
                        $("#btnpoplink").attr("href", response.ButtonLink);
                        $("#subscribe-form").hide();
                       
                    }  
                    // You can update the UI or handle the response data here
                },
                error: function (xhr, status, error) {
                    // Handle errors
                    console.log('Error:', error);
                    // You can display an error message or handle the failure case here
                }
            });

        }
            // else if (type == "On Exit Intent" && (persession == "" || persession == "always") && persession != idpop) {
        
        function triggertype(type) {
            var persession = '@Session["displaysession"]';
            var idpop = $("#closepop").val();

            if (type == "On Page Load" && persession != idpop) {
                $('#popup-container').css('display', 'flex');
                $('#popup-container').fadeIn();
            } else if (type == "On Scroll"  && persession != idpop) {
                // Show the modal when user scrolls down 50% of the page
                $(window).on('scroll', function () {
                    var scrollPosition = $(window).scrollTop();
                    var windowHeight = $(window).height();
                    var documentHeight = $(document).height();

                    if (scrollPosition > (documentHeight - windowHeight) / 2) {
                        $('#popup-container').css('display', 'flex')
                        $('#popup-container').fadeIn();
                        $(window).off('scroll'); // Unbind scroll event after showing modal
                    }
                });
            } else if (type == "On Exit Intent" && (persession == "" || persession == "always") && persession != idpop) {
                // Show the modal when user moves cursor towards the top of the page
                $(document).on('mouseleave', function (e) {
                    if (e.clientY < 10) {
                        e.preventDefault();
                        $('#popup-container').css('display', 'flex')
                        $('#popup-container').fadeIn();
                        $(document).off('mouseleave'); // Unbind mouseleave event after showing modal
                    }
                });
            }
        }
       function closetrigger() {
    var popid = $("#closepop").val();  // Get the popup ID

    $.ajax({
        url: "@Url.Action("poppersession", "Home")",  // The URL for the request
        type: 'POST',                                 // Request method (POST, GET, etc.)
        dataType: 'json',                             // Data type expected from the server
        contentType: 'application/x-www-form-urlencoded; charset=UTF-8', // Content type being sent to the server
        data: {
            id: popid  // Sending the ID to the server
        },
        success: function (response) {
            // Optionally handle success
            console.log('Session updated successfully');
        }

    });
}
    </script>
