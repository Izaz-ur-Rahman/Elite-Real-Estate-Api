

<!doctype html>
<html lang="en">

<head>
    <title>Elite Admin Panel</title>
    <meta charset="utf-8">
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>Estate</title>
    <meta name="robots" content="noindex, nofollow">
    <meta name="description" content="Droopy is a Dashboard & Admin Site Responsive Template by hencework." />
    <meta name="keywords" content="admin, admin dashboard, admin template, cms, crm, Droopy Admin, Droopyadmin, premium admin templates, responsive admin, sass, panel, software, ui, visualization, web app, application" />
    <meta name="author" content="hencework" />


    <!-- Favicon -->
    <link rel="shortcut icon" href="favicon.ico">
    <link rel="icon" href="favicon.ico" type="image/x-icon">

    <!-- Data table CSS -->
    <link href="~/Content/vendors/bower_components/datatables/media/css/jquery.dataTables.min.css" rel="stylesheet" type="text/css" />

    <!-- Toast CSS -->
    <link href="~/Content/vendors/bower_components/jquery-toast-plugin/dist/jquery.toast.min.css" rel="stylesheet" type="text/css">
    <link rel="stylesheet" href="~/Content/assets/vendor/toastr/toastr.min.css">
    <link rel="stylesheet" href="~/Content/assets/vendor/sweetalert/sweetalert.css" />
    <!-- Custom CSS -->
    <link href="~/Content/dist/css/style.css" rel="stylesheet" type="text/css">
    <style>
        .navbar.navbar-inverse.navbar-fixed-top .nav-header .logo-wrap .brand-img {
            margin-right: 0;
            position: relative;
            top: -4px;
        }

        .breadcrumb {
            float: left;
        }
        @@media (min-width: 992px) {
    .fixed-sidebar-left {
        width: 240px !important;
        left: 0 !important;
        visibility: visible !important;
        transform: translateX(0) !important;
        transition: none !important;
    }

    .wrapper {
        padding-left: 240px !important; /* Adjust content to not overlap with sidebar */
    }

    .fixed-sidebar-left .side-nav {
        display: block !important;
    }
}
@@media (min-width: 992px) {
    .fixed-sidebar-left .side-nav .right-nav-text {
        display: inline-block !important;
        opacity: 1 !important;
        visibility: visible !important;
    }

}

/* Hide the hamburger icon on larger screens */
@@media (min-width: 992px) {
    #toggle_nav_btn {
        display: none !important;
    }
        .mobile-only-brand {
            display: flex !important;
            align-items: center;
        }

        .brand-img {
            display: block !important;
            height: auto;
        }

        .brand-text {
            display: inline-block !important;
            opacity: 1 !important;
            visibility: visible !important;
            color: #fff; /* Or any contrasting color */
            font-weight: bold;
            margin-left: 10px;
        }
}

/* Show the hamburger on small screens */
@@media (max-width: 991px) {
    .mobile-only-nav {
        display: block !important;
    }
}

/* Mobile Menu Style - Ensure it overlays content without pushing */
/* Hide everything except logo and hamburger on small screen */
@@media (max-width: 991px) {
    .top-nav-search,
    .top-nav > li:not(#toggle_nav_btn):not(.auth-drp):not(.app-drp),
    .brand-text,
    .top-nav > li {
        display: none !important;
    }
        #toggle_mobile_search, #toggle_mobile_nav {
            display: none !important;
        }
        .mobile-only-brand {
            display: flex !important;
            align-items: center;
            justify-content: space-between;
            width: 100%;
        }

    #toggle_nav_btn {
        display: inline-block !important;
    }

    .brand-img {
        max-width: 200px;
        height: auto;
    }
}
@@media (max-width: 991px) {
 .fixed-sidebar-left {
    position: fixed;
    top: 55px;
    left: -240px; /* hide it initially */
    width:240px;
    height: 100%;
    background-color: #2a2a2a; /* adjust to your theme */
    z-index: 1000;
}

.wrapper.sidebar-open .fixed-sidebar-left {
    left: 0; /* show the sidebar */
}

.wrapper.sidebar-open {
    overflow: hidden; /* prevent scroll when menu is open */
}

#toggle_nav_btn {
    z-index: 1100; /* make sure hamburger is always on top */
}

        .wrapper.sidebar-open::after {
            content: "";
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: black;
            z-index: 900;
        }
        

}

/* Show the parent div (logo and search form) only on large screens */
@@media (min-width: 992px) {
        .parent {
            display: inline-flex !important; /* Show the parent div on large screens */
            align-items: center;
            padding: 8px;
        }

    .mobile-only-brand {
        display: none !important; /* Hide the mobile-specific brand */
    }

    .fixed-sidebar-left {
        /* Adjust sidebar for large screens */
        width: 240px !important;
        left: 0 !important;
        visibility: visible !important;
        transform: translateX(0) !important;
        transition: none !important;
    }

    .wrapper {
        padding-left: 240px !important;
    }

    .fixed-sidebar-left .side-nav {
        display: block !important;
    }
        .brand-img {
            width: 200px !important;
        }
}

/* Show the mobile navigation only on smaller screens */
@@media (max-width: 991px) {
    .parent {
        display: none !important;  /* Hide the parent div on small screens */
    }

    .mobile-only-brand {
        display: flex !important;
        align-items: center;
        justify-content: space-between;
        /*width: 100%;*/
    }

    #toggle_nav_btn {
        display: inline-block !important; /* Show hamburger icon on small screens */
    }

    .brand-img {
        max-width: 200px;
        height: auto;
       
    }

    .top-nav-search, .top-nav > li:not(#toggle_nav_btn):not(.auth-drp):not(.app-drp),
    .brand-text, .top-nav > li {
        display: none !important;
    }

    #toggle_mobile_search, #toggle_mobile_nav {
        display: none !important;
    }

    .mobile-only-nav {
        display: block !important;
    }
}

    </style>

</head>



<body>


    <div class="preloader-it">
        <div class="la-anim-1"></div>
    </div>
    <!-- /Preloader -->
    <div class="wrapper  theme-5-active pimary-color-green">
        <nav class="navbar navbar-inverse navbar-fixed-top">
