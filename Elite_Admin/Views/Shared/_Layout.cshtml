            </div>
            <div class="mobile-only-brand pull-left">
                <div class="nav-header pull-left">
                    <div class="logo-wrap">
                        <a href="~/Home/Index">
                            <img class="brand-img" src="~/Content/assets/images/Nav-Bar-Logo-clr.png" style="width:100%;">
                            @*<span class="brand-text">Elite Real Estate</span>*@
