<!-- Subscribe Footer Section -->
<div class="subscribe-footer mt-5 mb-5">
    <h3>Ready to Get Our New Stuff?</h3>
    <form id="subscribe-newsletter">
        <div class="input-group subscribe-input" style="width:100%">

            <input type="email" class="form-control" name="Email"placeholder="Enter Your Email" required>
            <input type="hidden" name="captchakey" id="captchakey" class="captchakey" />

            <button type="submit" class="btn btn-light">Subscribe</button>

        </div>
    </form>
</div>

<script type="text/javascript">
    document.addEventListener('DOMContentLoaded', function () {
        const buttons = document.querySelectorAll('.expand-btn');

        buttons.forEach(button => {
            button.addEventListener('click', function (event) {
                event.preventDefault(); // Prevent the default action of the button

                const content = this.previousElementSibling;
                content.classList.toggle('expanded');
                this.classList.toggle('expanded');
                this.textContent = this.classList.contains('expanded') ? 'Collapse' : 'Read more';
            });
        });
    });
</script>
<script type="text/javascript">
    document.addEventListener('DOMContentLoaded', function () {
        // Initialize the carousels manually
        var carousels = document.querySelectorAll('.carousel');
        carousels.forEach(function (carousel) {
            new bootstrap.Carousel(carousel, {
                interval: false
            });
        });

        // Existing code for expand/collapse functionality
        const buttons = document.querySelectorAll('.expand-btn');
        buttons.forEach(button => {
            button.addEventListener('click', function (event) {
                event.preventDefault(); // Prevent the default action of the button
                const content = this.previousElementSibling;
                content.classList.toggle('expanded');
                this.classList.toggle('expanded');
                this.textContent = this.classList.contains('expanded') ? 'Collapse' : 'Read more';
            });
        });
    });
</script>


