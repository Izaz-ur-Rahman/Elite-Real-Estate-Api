            background-color: #d3d3d3;
        }

    .social-links a {
        margin: 0 0px;
        color: #333;
    }

    .article-title {
        font-size: 2rem;
        margin-bottom: 20px;
    }

    .article-section {
        margin-bottom: 40px;
    }

    .author-img {
        width: 151px;
        height: 151px;
        border-radius: 50%;
    }

    .author-detail {
        font-size: 20px;
        font-weight: 600;
    }

    .social-img {
        width: 30px;
        height: 30px;
    }

    .cart-main {
        display: flex;
        justify-content: flex-start;
        align-items: center;
    }

    .sm-img {
        width: 40px;
        height: 40px;
        border-radius: 50%;
    }

    .cart-wriiten {
        margin-bottom: 5px;
        font-size: 12px;
        font-weight: 500;
        color: #AAAAAA !important;
    }

    .cart-nadeem {
        margin-bottom: 0px;
        font-size: 12px !important;
        font-weight: 600 !important;
        color: black !important;
    }

    .tags {
        padding: 10px;
        border-radius: 10px;
        margin: 2px;
        border: none;
        background-color: lightgray;
    }
</style>

