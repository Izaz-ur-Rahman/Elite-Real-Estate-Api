
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_LayoutWebsite.cshtml";
}

@*<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">*@


<style>
   

    .ai-banner {
        background-color: #1c1c2b;
        background-image: url('../../content/websiteassets/assets/img/blogs-img/image.png');
        padding: 60px 0;
        text-align: center;
        color: #fff;
        height: 530px;
        background-size: 100% 100%;
        background-position: center;
    }

        .ai-banner img {
            max-width: 100px;
        }

    .content-wrapper {
        padding: 20px;
    }

    .author-profile {
        margin-bottom: 20px;
    }

        .author-profile img {
            /* width: 100px; */
